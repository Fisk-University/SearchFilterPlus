document.addEventListener('DOMContentLoaded', function() {
    initDateRangeSlider(
        <?php echo json_encode([
            'minYear' => $minYear,
            'maxYear' => $maxYear,
            'startYear' => $startYear,
            'endYear' => $endYear,
            'autoSubmit' => true,
        ]); ?>
    );
});
</script>